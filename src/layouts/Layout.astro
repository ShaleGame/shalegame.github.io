---
import HeaderNav from '../components/HeaderNav.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Shale</title>
		<meta name="description" content="Shale — an atmospheric puzzle-adventure set in caverns and abandoned laboratories." />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Merriweather:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
		<!-- Open Graph / Social -->
		<meta property="og:title" content="Shale" />
		<meta property="og:description" content="Explore abandoned caverns and secret laboratories in this atmospheric puzzle-adventure." />
		<meta property="og:type" content="website" />
		<meta property="og:image" content="/social-preview.png" />
		<meta name="twitter:card" content="summary_large_image" />
	</head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <HeaderNav />
    <slot />
  </body>
</html>

  <style is:global>
	:root {
		--bg: #0b0c10;
		--muted: #94a3b8;
		--accent: #3dd1c1;
		--accent2: #ff7b50;
		--card: rgba(255,255,255,0.03);
	}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		background: var(--bg);
		color: #e6eef2;
		font-family: "Merriweather", Georgia, "Times New Roman", serif;
	}

	a { color: var(--accent); }

  .button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 10px 20px;
		text-decoration: none;
		font-weight: 600;
		border: 1px solid transparent;
		transition: transform 160ms ease, box-shadow 160ms ease;
		font-family: "Space Grotesk", "Inter", "Segoe UI", sans-serif;
		white-space: nowrap;
		cursor: pointer;
	}

	.button.primary {
		background: white;
		color: #030709;
	}

	.button.ghost {
		color: #f4f7ff;
		background: transparent;
	}

	.button:hover {
		transform: translateY(-1px);
  }

  /* Skip link styles: hidden until focused */
  .skip-link {
    position: absolute;
    left: -9999px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
    background: #fff;
    color: #000;
    padding: 8px 12px;
    z-index: 1000;
    border-radius: 4px;
    text-decoration: none;
  }

  .skip-link:focus {
    left: 12px;
    top: 12px;
    width: auto;
    height: auto;
    overflow: visible;
  }
</style>
