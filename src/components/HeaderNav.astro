---
const navItems = [
  { href: '/', label: 'Home' },
  // Use a short label for small screens but keep the full label available
  // for wider viewports and accessibility.
  { href: '/project-description', label: 'Project', fullLabel: 'Project description' },
  { href: '/releases', label: 'Releases' },
];
const currentPath = Astro.url.pathname;
const isActive = (href) => currentPath === href || currentPath === href + '/';
---

<header class="site-header">
  <nav class="header-nav">
    {navItems.map((item) => (
      <a
        class={isActive(item.href) ? 'active' : ''}
        href={item.href}
        aria-current={currentPath === item.href ? 'page' : undefined}
        data-fulllabel={item.fullLabel ?? item.label}
        title={item.fullLabel ?? item.label}
      >
        <span class="label-short">{item.label}</span>
        <span class="label-full">{item.fullLabel ?? item.label}</span>
      </a>
    ))}
  </nav>
</header>

<style>
  :global(.site-header) {
    position: relative;
    z-index: 10;
    height: 30px;
    background: #000000;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
  }

  :global(.header-nav) {
    display: flex;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: flex-end;
    padding: 0 1.5rem;
    font-family: "Space Grotesk", "Inter", "Segoe UI", sans-serif;
  }

  :global(.header-nav a) {
    color: #e6eef2;
    text-decoration: none;
    padding: 0 1rem;
    line-height: 30px;
    text-transform: uppercase;
    font-size: 10pt;
    font-weight: 700;
    /* Prevent wrapping on small viewports. We'll reveal the full label
       on wider screens (see rule below). */
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* By default show the short label and hide the full label. On wider
     viewports reveal the full label (keeps desktop experience unchanged). */
  :global(.header-nav a .label-full) {
    display: none;
  }

  @media (min-width: 480px) {
    :global(.header-nav a .label-short) {
      display: none;
    }
    :global(.header-nav a .label-full) {
      display: inline;
    }
  }

  :global(.header-nav a.active) {
    background: #ffffff;
    color: #000000;
  }
</style>
