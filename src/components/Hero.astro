---
const repoUrl = 'https://github.com/ShaleGame/ShaleGame';
import gameplay from '../assets/shale-gameplay.mp4';
---


<section class="hero">
  <video class="hero-video" autoplay muted loop playsinline aria-hidden="true">
    <source src={gameplay} type="video/mp4" />
  </video>

  <div class="hero-inner">
    <div class="hero-copy">
      <h1>Shale</h1>
    </div>
  </div>
</section>

<section class="cta-strip">
  <div class="cta-inner">
    <p class="cta-copy">
      Currently in development.
    </p>
    <div class="cta-row">
      <a class="button primary" href={repoUrl} rel="noopener" target="_blank">View Development on GitHub</a>
      <a class="button ghost" href="/releases" rel="noopener">Release notes</a>
      <a class="button ghost" href="/project-description">Project description</a>
    </div>
  </div>
</section>

<style>
  :global(:root) {
    --bg: #000;
    --muted: #9aa3b3;
    --accent: #3dd1c1;
    --accent2: #ff7b50;
  }

  .hero {
    min-height: 100vh;
    background: #000;
    color: #f0f4ff;
    padding: clamp(3.5rem, 4vw, 6rem) 1.25rem;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  /* darken the left side of the hero with a gradient so the right half
     of the video remains at normal brightness */
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.58) 25%, rgba(0,0,0,0.18) 45%, rgba(0,0,0,0) 65%);
    pointer-events: none;
    z-index: 1;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    pointer-events: none;
  }

  /* ensure inner content stays above the video */
  .hero-inner {
    position: relative;
    z-index: 3;
  }

  .hero-inner {
    width: 100%;
    max-width: 960px;
    position: relative;
    z-index: 3;
    margin: 0 auto;
  }

  .hero-copy h1 {
    font-size: clamp(3rem, 6vw, 4.25rem);
    margin: 0.35rem 0;
    letter-spacing: -0.02em;
  }

  .hero-copy h1 + .pitch {
    margin-top: 0.75rem;
  }

  .pitch {
    color: var(--muted);
    font-size: clamp(1.125rem, 2vw, 1.35rem);
    line-height: 1.6;
    max-width: 48ch;
  }

  .meta {
    color: #7d8ea2;
    font-size: 0.95rem;
    margin-top: 1rem;
  }

  .cta-strip {
    background: #000;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: clamp(1.5rem, 2vw, 2.75rem) 1.25rem clamp(2.5rem, 3vw, 3.5rem);
  }

  .cta-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    align-items: center;
    text-align: center;
  }

  .cta-copy {
    color: var(--muted);
    max-width: 64ch;
    font-size: 1.1rem;
    letter-spacing: 10px;
    text-transform: uppercase;
    margin: 0;
  }

  .cta-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    width: 100%;
  }

  @media (max-width: 640px) {
    .cta-row {
      flex-direction: column;
    }
  }
</style>
